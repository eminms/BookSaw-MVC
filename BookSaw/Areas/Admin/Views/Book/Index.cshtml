@using BookSaw.Models
@model List<Book>
@{
    int counter = 1;
}

<!-- DataTales Example -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Products</h6>
        <a asp-area="Admin" asp-controller="Book" asp-action="Create" class="btn btn-success">Add Book</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Id</th>
                        <th>ImgUrl</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Price</th>
                        <th>Description</th>
                        <th>Publisher</th>
                        <th>ISBN</th>
                        <th>Language</th>
                        <th>Pages</th>
                        <th>Category</th>
                        <th>Edit</th>
                        <th>Delete</th>

                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {

                        <tr>
                            <td>@counter</td>
                            <td>@item.Id</td>
                            <td><img src="~/images/@item.ImgUrl" width="100" height="100"></td>
                            <td>@item.Title</td>
                            <td>@item.Author</td>
                            <td>@item.Price</td>
                            <td>@item.Description</td>
                            <td>@item.Publisher</td>
                            <td>@item.ISBN</td>
                            <td>@item.Language</td>
                            <td>@item.Pages</td>
                             <td>@foreach(var category in item.Categories)
                                {
                                    @category.Name <br/>
                                }
                            </td> 
                            <td>
                                <a asp-area="Admin" asp-controller="Book" asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                            </td>
                            <td>
                                <form asp-area="Admin" asp-controller="Book" asp-action="Delete" asp-route-id="@item.Id">
                                <button type="submit" class="btn btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                        counter++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>